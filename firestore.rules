
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 🛡️ SECURITY CORE: Development Mode Setup
    // Temporary relaxation applied for full feature testing.
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // 👤 User Profile - Optimized for Development Testing
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
                    
      // TEMPORARY: Relaxed diff check for testing 'Watch & Earn' and profile sync.
      // RECOMMENDED FOR PRODUCTION: Re-enable strict affectedKeys() check for 'isAdmin' and 'subscriptionPlan'.
      allow update: if isOwner(userId) || isAdmin();
      
      allow delete: if isAdmin();
      
      match /projects/{projectId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /diagnostics/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /connection_tests/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    match /users {
      allow list: if isAdmin();
    }
  }
}
