
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 🛡️ SECURITY CORE: Elite Level Production Rules
    // Prevents unauthorized access and protects owner data.
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // 👤 User Profile - Optimized for Credit Updates
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow creation for own node
      allow create: if isOwner(userId);
                    
      // SECURITY CRITICAL: Owner can update credits but NOT their own Admin/Premium status.
      // Only an existing Admin can grant status or upgrade plans.
      allow update: if (isOwner(userId) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'subscriptionPlan', 'isPremium'])
      )) || isAdmin();
      
      allow delete: if isAdmin();
      
      // 📽️ Projects sub-collection - Node Owner access only
      match /projects/{projectId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // 🧪 Diagnostics - Technical Monitoring
      match /diagnostics/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // 🌐 Connection Tests - Public verified nodes for diagnostics
    match /connection_tests/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    // 🛡️ Master Admin List Clearance
    match /users {
      allow list: if isAdmin();
    }
  }
}
