
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 🛡️ SECURITY CORE: Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // 👤 User Profile - Restricted Access
    match /users/{userId} {
      // Users can only read/write their own profiles
      allow read: if isOwner(userId) || isAdmin();
      
      // Prevent users from giving themselves unlimited credits or admin status
      allow create, update: if isOwner(userId) && 
                            (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'subscriptionPlan']) || isAdmin());
      
      // Global admin management access
      allow delete: if isAdmin();
      
      // 📽️ Projects sub-collection - Secured access
      match /projects/{projectId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // 🧪 Diagnostics/Global data - Restricted for security
    match /connection_tests/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    // 📊 Global User Listing - Restricted to Admins only
    match /users {
      allow list: if isAdmin();
    }
  }
}
