rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 🛡️ SECURITY CORE: Elite Level Production Rules
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // 👤 User Profile - Strict Synchronization
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow creation only for own node with default roles
      allow create: if isOwner(userId) && 
                    (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'subscriptionPlan', 'isPremium']) || isAdmin());
                    
      // Only owner can update metadata, but restricted keys (roles/billing) require admin node
      allow update: if isOwner(userId) && 
                    (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'subscriptionPlan', 'isPremium']) || isAdmin()); 
      
      allow delete: if isAdmin();
      
      // 📽️ Projects sub-collection - Node Owner access only
      match /projects/{projectId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // 🧪 Diagnostics - Technical Monitoring
      match /diagnostics/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // 🌐 Connection Tests - Public verified nodes
    match /connection_tests/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    // 🛡️ Master Admin List Clearance
    match /users {
      allow list: if isAdmin();
    }
  }
}