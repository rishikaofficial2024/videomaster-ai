
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 🛡️ INSTITUTIONAL SECURITY PROTOCOLS
    
    const OWNER_EMAIL = "rinkukumarpaswan1796@gmail.com";

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMaster() {
      return isAuthenticated() && request.auth.token.email == OWNER_EMAIL;
    }

    function isAdmin() {
      return isMaster() || (
             isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (getUserData().isAdmin == true || getUserData().role == 'admin' || getUserData().role == 'super_admin')
      );
    }

    function isModerator() {
      return isAdmin() || (
             isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role == 'moderator'
      );
    }

    // 👤 User Profile - Master Clearance Check
    match /users/{userId} {
      allow read: if isOwner(userId) || isModerator();
      allow create: if isAuthenticated() && request.auth.uid == userId;
                    
      // Owner can update everything. Admins can update roles/credits.
      allow update: if isMaster() || (
                    isAdmin() && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['email'])
      ) || (
                    isOwner(userId) && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'email', 'role', 'status'])
      );
      
      allow delete: if isMaster();
      
      match /projects/{projectId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /diagnostics/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // 🎥 Global Templates
    match /templates/{templateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 📊 Institutional Analytics
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); 
      allow update, delete: if isMaster();
    }

    // 📜 Admin Audit Logs
    match /admin_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // Logs are immutable
    }

    match /connection_tests/{docId} {
      allow read, write: if isAuthenticated();
    }
  }
}
