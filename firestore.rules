
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 🛡️ SECURITY CORE: Elite Level Production Rules
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // 👤 User Profile - Optimized for Credit Updates
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
                    
      // Allows owner to update credits but protects Admin/Premium status
      allow update: if (isOwner(userId) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'subscriptionPlan', 'isPremium'])
      )) || isAdmin();
      
      allow delete: if isAdmin();
      
      match /projects/{projectId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /diagnostics/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /connection_tests/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    match /users {
      allow list: if isAdmin();
    }
  }
}
