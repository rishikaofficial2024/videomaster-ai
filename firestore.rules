
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for security
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // User Profile rules - Strict Isolation
    match /users/{userId} {
      // Allow read/write if the user is accessing their own data
      allow read, write: if isOwner(userId);
      
      // Global admin management access for studio operations
      allow read, write: if isAdmin();
      
      // Projects sub-collection - Secured access
      match /projects/{projectId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Diagnostics/Global data - Open for testing connectivity
    match /connection_tests/{docId} {
      allow read, write: if true;
    }
    
    // Global User Listing - Restricted to Admins only
    match /users {
      allow list: if isAdmin();
    }
  }
}
