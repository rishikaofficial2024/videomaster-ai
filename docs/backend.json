{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and subscription details",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "credits": { "type": "number" },
        "subscriptionPlan": { "type": "string", "enum": ["free", "pro", "business"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "Project": {
      "title": "Project",
      "description": "A video editing project",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "exported", "processing"] },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Individual user accounts"
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": { "$ref": "#/backend/entities/Project" },
      "description": "User's editing projects"
    }
  }
}