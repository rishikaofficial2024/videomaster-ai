{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Comprehensive user profile including subscription metrics and usage data",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "isAdmin": { "type": "boolean", "description": "Global admin privileges" },
        "subscriptionPlan": { "type": "string", "enum": ["free", "pro", "business"] },
        "credits": { "type": "number", "description": "Available AI processing credits" },
        "totalSpent": { "type": "number", "description": "Total lifetime revenue from user" },
        "usageStats": {
          "type": "object",
          "properties": {
            "totalVideos": { "type": "number" },
            "aiGenerations": { "type": "number" }
          }
        }
      },
      "required": ["email"]
    },
    "VideoProject": {
      "title": "Video Project",
      "description": "Professional video project metadata including AI assets and multi-track media",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "processing", "completed", "error"] },
        "category": { "type": "string", "enum": ["social", "business", "personal", "ads"] },
        "duration": { "type": "number", "description": "Duration in seconds" },
        "aspectRatio": { "type": "string", "enum": ["16:9", "9:16", "1:1"] },
        "transcript": { "type": "string" },
        "optimizedTitle": { "type": "string" },
        "optimizedDescription": { "type": "string" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "thumbnailUrl": { "type": "string" },
        "videoDataUri": { "type": "string" },
        "audioDataUri": { "type": "string", "description": "Primary voiceover track" },
        "backgroundMusicUrl": { "type": "string", "description": "Active background music track" },
        "mediaAssets": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "url": { "type": "string" },
              "type": { "type": "string", "enum": ["image", "video", "audio"] },
              "label": { "type": "string" }
            }
          }
        },
        "subtitles": { "type": "string" },
        "aiNotes": { "type": "string", "description": "AI recommendations for the video" }
      },
      "required": ["title", "createdAt", "status"]
    }
  },
  "auth": {
    "providers": ["google.com", "facebook.com", "github.com", "phone", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "The user's core profile and billing state."
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": { "$ref": "#/backend/entities/VideoProject" },
      "description": "User's video editing projects collection."
    }
  }
}