
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stored user preferences, subscription status, and credit balance",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "subscriptionPlan": { "type": "string", "enum": ["free", "pro", "business"] },
        "credits": { "type": "number", "description": "AI processing credits balance" },
        "totalSpent": { "type": "number", "description": "Total revenue from this user" }
      },
      "required": ["email"]
    },
    "VideoProject": {
      "title": "Video Project",
      "description": "Metadata and AI analysis for a video project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "processing", "completed"] },
        "transcript": { "type": "string" },
        "optimizedTitle": { "type": "string" },
        "optimizedDescription": { "type": "string" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "thumbnailUrl": { "type": "string" },
        "videoDataUri": { "type": "string" },
        "subtitles": { "type": "string" }
      },
      "required": ["title", "createdAt", "status"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "The user's root profile document."
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": { "$ref": "#/backend/entities/VideoProject" },
      "description": "Collection of video projects owned by the user."
    }
  }
}
