
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Comprehensive user profile including subscription metrics and usage data",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "isAdmin": { "type": "boolean", "description": "Legacy admin flag" },
        "role": { "type": "string", "enum": ["user", "moderator", "admin", "super_admin", "owner"] },
        "status": { "type": "string", "enum": ["active", "suspended", "banned"] },
        "subscriptionPlan": { "type": "string", "enum": ["free", "pro", "business"] },
        "credits": { "type": "number" },
        "totalSpent": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "AdminLog": {
      "title": "Admin Audit Log",
      "description": "Immutable record of administrative actions for security audits.",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "adminEmail": { "type": "string" },
        "action": { "type": "string" },
        "targetId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User identity and role node."
    },
    "/admin_logs/{logId}": {
      "schema": { "$ref": "#/backend/entities/AdminLog" },
      "description": "Institutional activity ledger."
    }
  }
}
