
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stored user preferences and subscription status",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "credits": { "type": "number", "description": "AI processing credits" }
      },
      "required": ["email"]
    },
    "VideoProject": {
      "title": "Video Project",
      "description": "Metadata and AI analysis for a video project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "processing", "completed"] },
        "transcript": { "type": "string" },
        "optimizedTitle": { "type": "string" },
        "optimizedDescription": { "type": "string" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "thumbnailUrl": { "type": "string" }
      },
      "required": ["title", "createdAt", "status"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "The user's root profile document"
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": "VideoProject",
      "description": "Collection of video projects owned by the user"
    }
  }
}
